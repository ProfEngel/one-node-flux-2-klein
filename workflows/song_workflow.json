{
  "SONG:model": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "acestep_v1.5_xl_turbo_bf16.safetensors",
      "weight_dtype": "default"
    },
    "_meta": {"title": "Load ACE-Step Model"}
  },
  "SONG:clip": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "qwen_0.6b_ace15.safetensors",
      "clip_name2": "qwen_1.7b_ace15.safetensors",
      "type": "ace",
      "device": "default"
    },
    "_meta": {"title": "Load ACE-Step Text Encoders"}
  },
  "SONG:vae": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ace_1.5_vae.safetensors"},
    "_meta": {"title": "Load ACE-Step VAE"}
  },
  "SONG:latent": {
    "class_type": "EmptyAceStep1.5LatentAudio",
    "inputs": {"seconds": 180.0, "batch_size": 1},
    "_meta": {"title": "Empty Song Latent"}
  },
  "SONG:positive": {
    "class_type": "TextEncodeAceStepAudio1.5",
    "inputs": {
      "clip": ["SONG:clip", 0],
      "tags": "",
      "lyrics": "",
      "seed": 1,
      "bpm": 120,
      "duration": 180.0,
      "timesignature": "4",
      "language": "de",
      "keyscale": "E minor",
      "generate_audio_codes": true,
      "cfg_scale": 2.0,
      "temperature": 0.85,
      "top_p": 0.9,
      "top_k": 0,
      "min_p": 0.0
    },
    "_meta": {"title": "Encode Song"}
  },
  "SONG:negative": {
    "class_type": "ConditioningZeroOut",
    "inputs": {"conditioning": ["SONG:positive", 0]},
    "_meta": {"title": "Zero Negative Conditioning"}
  },
  "SONG:sampling": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {"model": ["SONG:model", 0], "shift": 3.5},
    "_meta": {"title": "ACE-Step Sampling"}
  },
  "SONG:sampler": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["SONG:sampling", 0],
      "seed": 1,
      "steps": 50,
      "cfg": 2.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["SONG:positive", 0],
      "negative": ["SONG:negative", 0],
      "latent_image": ["SONG:latent", 0],
      "denoise": 1.0
    },
    "_meta": {"title": "Generate Song"}
  },
  "SONG:decode": {
    "class_type": "VAEDecodeAudio",
    "inputs": {"samples": ["SONG:sampler", 0], "vae": ["SONG:vae", 0]},
    "_meta": {"title": "Decode Song"}
  },
  "SONG:save": {
    "class_type": "SaveAudioMP3",
    "inputs": {
      "audio": ["SONG:decode", 0],
      "filename_prefix": "audio/OneNode_Song",
      "quality": "320k"
    },
    "_meta": {"title": "Save Song"}
  }
}
